{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superagent.dev/schemas/spec-challenge.schema.json",
  "title": "Spec Challenge Artifact",
  "type": "object",
  "required": ["phase", "role", "run_id", "created_at", "sources", "status", "loop_number", "findings"],
  "properties": {
    "phase": { "const": "spec_challenge" },
    "role": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "sources": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "minLength": 1 },
    "loop_number": { "type": "integer", "minimum": 0 },
    "findings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
