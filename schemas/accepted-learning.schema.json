{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superagent.dev/schemas/accepted-learning.schema.json",
  "title": "Accepted Learning Artifact",
  "type": "object",
  "required": ["phase", "role", "run_id", "created_at", "sources", "status", "loop_number", "scope", "confidence", "review_date"],
  "properties": {
    "phase": { "const": "learn" },
    "role": { "const": "learner" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "sources": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "minLength": 1 },
    "loop_number": { "type": "integer", "minimum": 0 },
    "scope": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "review_date": { "type": "string", "format": "date" }
  },
  "additionalProperties": true
}
