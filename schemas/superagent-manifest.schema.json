{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superagent.dev/schemas/superagent-manifest.schema.json",
  "title": "SuperAgent Manifest v2",
  "type": "object",
  "required": [
    "manifest_version",
    "project",
    "versioning_policy",
    "paths",
    "hosts",
    "workflows",
    "phases",
    "roles",
    "export_targets",
    "required_hooks",
    "protected_paths",
    "prohibited_terms",
    "adapters",
    "index",
    "validation_checks"
  ],
  "properties": {
    "manifest_version": {
      "const": 2
    },
    "project": {
      "type": "object",
      "required": ["name", "display_name", "version", "description", "license"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "versioning_policy": {
      "type": "object",
      "required": ["strategy", "stability", "compatibility"],
      "properties": {
        "strategy": { "type": "string", "minLength": 1 },
        "stability": { "type": "string", "minLength": 1 },
        "compatibility": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "required": [
        "roles",
        "workflows",
        "skills",
        "hooks",
        "templates",
        "schemas",
        "expertise",
        "docs",
        "exports",
        "tooling",
        "examples",
        "state_root_default"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "hosts": {
      "type": "array",
      "items": {
        "enum": ["claude", "codex", "gemini", "cursor"]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "workflows": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "minItems": 1
    },
    "phases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "minItems": 1
    },
    "roles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "minItems": 1
    },
    "export_targets": {
      "type": "array",
      "items": {
        "enum": ["claude", "codex", "gemini", "cursor"]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "required_hooks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "minItems": 1
    },
    "protected_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "minItems": 1
    },
    "prohibited_terms": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "minItems": 1
    },
    "adapters": {
      "type": "object",
      "required": ["context_mode"],
      "properties": {
        "context_mode": { "$ref": "#/$defs/adapter" },
        "open_pencil": { "$ref": "#/$defs/adapter" }
      },
      "additionalProperties": false
    },
    "index": {
      "type": "object",
      "required": ["core_parsers", "optional_language_plugins"],
      "properties": {
        "core_parsers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "optional_language_plugins": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "validation_checks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "adapter": {
      "type": "object",
      "required": [
        "enabled_by_default",
        "required",
        "install_mode",
        "package_presence"
      ],
      "properties": {
        "enabled_by_default": { "type": "boolean" },
        "required": { "type": "boolean" },
        "install_mode": { "enum": ["external"] },
        "package_presence": { "enum": ["optional"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
