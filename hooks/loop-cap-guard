#!/usr/bin/env node

import { readFileSync } from 'node:fs';

import { evaluateLoopCapGuard } from '../tooling/src/guards/loop-cap-guard.js';

try {
  const input = readFileSync(0, 'utf8');
  const payload = input.trim() ? JSON.parse(input) : {};
  const decision = evaluateLoopCapGuard(payload);

  process.stdout.write(`${JSON.stringify({ guard_decision: decision })}\n`);
  process.exit(decision.allowed ? 0 : 43);
} catch (error) {
  process.stderr.write(`${error.message}\n`);
  process.exit(1);
}
